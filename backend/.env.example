APP_NAME=InfluenceIA
# local | production
APP_ENV=local
# IMPORTANT: generate once with `php artisan key:generate` and NEVER regenerate after first deploy.
# Copy this value to Render's Environment Variables dashboard.
APP_KEY=
APP_DEBUG=true
# Local dev: http://localhost:8000 | Production: https://<your-service>.onrender.com
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Production: set to warning or error to reduce noise
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Local: mysql pointing to your local MySQL server
# Render: use your external managed DB credentials (PlanetScale, Render Postgres, etc.)
# If using Postgres on Render, change DB_CONNECTION=pgsql and DB_PORT=5432
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=influenceia
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
# For a stateless token-based API (Sanctum Bearer) these are largely irrelevant,
# but keep SESSION_DRIVER=file for local dev and cookie for production if needed.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Production: switch to s3 once you configure AWS/Cloudinary for file uploads
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@influenceia.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:5173 (Vite default)
# Production: set to your deployed Vercel frontend URL, e.g. https://influenceia.vercel.app
FRONTEND_URL=http://localhost:5173

# Sanctum stateful domains (only relevant for cookie/session auth — not Bearer tokens)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,127.0.0.1:5173,127.0.0.1:8000,localhost

# ── AWS S3 (optional — for file upload storage in production) ─────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
