# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment variables — copy this file to .env.local for local dev
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Never put secrets here.
#
# Local dev: the Vite dev server proxies to http://localhost:8000
# Production (Vercel): set VITE_API_URL in Vercel's Environment Variables dashboard
#   → Project Settings → Environment Variables → VITE_API_URL = https://<your-service>.onrender.com
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for the Laravel API (no trailing slash)
VITE_API_URL=http://localhost:8000
